<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Sigil.Windows.App.Views.ServerListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Sigil.Windows.App.Models"
    xmlns:viewmodels="using:Sigil.Windows.App.ViewModels"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- Empty State -->
        <StackPanel
            Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
            Spacing="20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            MaxWidth="400"
            Padding="48">

            <TextBlock
                Text="🔑"
                FontSize="64"
                Opacity="0.3"
                HorizontalAlignment="Center"
                AutomationProperties.AccessibilityView="Raw" />

            <TextBlock
                Text="No Servers Paired"
                Style="{StaticResource TitleTextBlockStyle}"
                HorizontalAlignment="Center" />

            <TextBlock
                Text="Pair your first server to start approving authentication requests. You can pair via URL or QR code."
                Style="{StaticResource BodyTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap"
                TextAlignment="Center"
                HorizontalAlignment="Center" />

            <Button
                Content="Pair Your First Server"
                Command="{x:Bind ViewModel.AddServerCommand}"
                Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Center"
                Padding="24,12"
                AutomationProperties.Name="Pair your first server"
                AutomationProperties.HelpText="Opens the pairing flow to add a new server" />
        </StackPanel>

        <!-- Server List -->
        <Grid
            Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Command Bar -->
            <CommandBar
                Grid.Row="0"
                DefaultLabelPosition="Right"
                Background="Transparent">
                <CommandBar.PrimaryCommands>
                    <AppBarButton
                        Icon="Add"
                        Label="Add Server"
                        Command="{x:Bind ViewModel.AddServerCommand}"
                        AutomationProperties.Name="Add new server"
                        AutomationProperties.HelpText="Opens the pairing flow to add a new server" />
                    <AppBarButton
                        Icon="Refresh"
                        Label="Refresh"
                        Command="{x:Bind ViewModel.RefreshServersCommand}"
                        AutomationProperties.Name="Refresh server list" />
                </CommandBar.PrimaryCommands>
            </CommandBar>

            <!-- Server ListView -->
            <ListView
                Grid.Row="1"
                ItemsSource="{x:Bind ViewModel.Servers, Mode=OneWay}"
                SelectionMode="Single"
                IsItemClickEnabled="False"
                Padding="24,12">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ServerConfig">
                        <Grid
                            Padding="16,12"
                            ColumnSpacing="16"
                            AutomationProperties.Name="{x:Bind Name}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Server Info -->
                            <StackPanel
                                Grid.Column="0"
                                Spacing="8">

                                <!-- Server Name -->
                                <TextBlock
                                    Text="{x:Bind Name}"
                                    Style="{StaticResource SubtitleTextBlockStyle}"
                                    AutomationProperties.HeadingLevel="Level2" />

                                <!-- Pictogram Emojis (inline) -->
                                <StackPanel
                                    Orientation="Horizontal"
                                    Spacing="4"
                                    AutomationProperties.AccessibilityView="Raw">
                                    <TextBlock
                                        Text="{x:Bind Pictogram.Entries[0].Emoji}"
                                        FontSize="24" />
                                    <TextBlock
                                        Text="{x:Bind Pictogram.Entries[1].Emoji}"
                                        FontSize="24" />
                                    <TextBlock
                                        Text="{x:Bind Pictogram.Entries[2].Emoji}"
                                        FontSize="24" />
                                    <TextBlock
                                        Text="{x:Bind Pictogram.Entries[3].Emoji}"
                                        FontSize="24" />
                                    <TextBlock
                                        Text="{x:Bind Pictogram.Entries[4].Emoji}"
                                        FontSize="24" />
                                    <TextBlock
                                        Text="{x:Bind Pictogram.Entries[5].Emoji}"
                                        FontSize="24" />
                                </StackPanel>

                                <!-- Speakable -->
                                <TextBlock
                                    Text="{x:Bind Pictogram.Speakable}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    AutomationProperties.Name="{x:Bind Pictogram.Speakable}" />
                            </StackPanel>

                            <!-- Paired Date -->
                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind PairedAt}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>

    <Page.Resources>
        <!-- BoolNegationConverter for inverting IsEmpty visibility -->
        <views:BoolNegationConverter x:Key="BoolNegationConverter"
                                     xmlns:views="using:Sigil.Windows.App.Views" />
    </Page.Resources>
</Page>
