<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Sigil.Windows.App.Views.ApprovalView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:Sigil.Windows.App.ViewModels"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel
            Padding="24"
            Spacing="24"
            MaxWidth="450"
            HorizontalAlignment="Center"
            MinHeight="400">

            <!-- Server Info with Pictogram -->
            <StackPanel Spacing="12">
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="12"
                    HorizontalAlignment="Center">
                    <FontIcon
                        Glyph="&#xE968;"
                        FontSize="24"
                        Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                    <TextBlock
                        Text="{x:Bind ViewModel.ServerName, Mode=OneWay}"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        VerticalAlignment="Center" />
                </StackPanel>

                <!-- Server Pictogram Display -->
                <StackPanel
                    Visibility="{x:Bind ViewModel.ServerPictogram, Mode=OneWay, Converter={StaticResource NullToCollapsedConverter}}"
                    Orientation="Horizontal"
                    Spacing="4"
                    HorizontalAlignment="Center"
                    AutomationProperties.AccessibilityView="Raw">
                    <TextBlock
                        Text="{x:Bind ViewModel.ServerPictogram.Entries[0].Emoji, Mode=OneWay}"
                        FontSize="20" />
                    <TextBlock
                        Text="{x:Bind ViewModel.ServerPictogram.Entries[1].Emoji, Mode=OneWay}"
                        FontSize="20" />
                    <TextBlock
                        Text="{x:Bind ViewModel.ServerPictogram.Entries[2].Emoji, Mode=OneWay}"
                        FontSize="20" />
                    <TextBlock
                        Text="{x:Bind ViewModel.ServerPictogram.Entries[3].Emoji, Mode=OneWay}"
                        FontSize="20" />
                    <TextBlock
                        Text="{x:Bind ViewModel.ServerPictogram.Entries[4].Emoji, Mode=OneWay}"
                        FontSize="20" />
                    <TextBlock
                        Text="{x:Bind ViewModel.ServerPictogram.Entries[5].Emoji, Mode=OneWay}"
                        FontSize="20" />
                </StackPanel>
            </StackPanel>

            <!-- Divider -->
            <Border
                Height="1"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Action Details Card -->
            <Border
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
                <StackPanel Spacing="12">

                    <!-- Action Description -->
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="12">
                        <FontIcon
                            Glyph="&#xE8D7;"
                            FontSize="20"
                            Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.ActionDescription, Mode=OneWay}"
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            VerticalAlignment="Center"
                            AutomationProperties.HeadingLevel="Level2" />
                    </StackPanel>

                    <!-- Action Details -->
                    <TextBlock
                        Text="{x:Bind ViewModel.ActionDetails, Mode=OneWay}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />

                    <!-- Expiry Timer -->
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8">
                        <TextBlock
                            Text="Expires:"
                            Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.TimeRemainingText, Mode=OneWay}"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            AutomationProperties.LiveSetting="Polite"
                            AutomationProperties.Name="{x:Bind ViewModel.TimeRemainingText, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Spacer />

            <!-- Action Buttons -->
            <StackPanel
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="12"
                Margin="0,12,0,0">
                <Button
                    Content="Deny"
                    Command="{x:Bind ViewModel.DenyCommand}"
                    MinWidth="140"
                    AutomationProperties.Name="Deny this approval request"
                    AutomationProperties.HelpText="Press Escape to deny" />
                <Button
                    Command="{x:Bind ViewModel.ApproveCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    MinWidth="140"
                    IsEnabled="{x:Bind ViewModel.CanApprove(), Mode=OneWay}"
                    AutomationProperties.Name="Approve with Windows Hello"
                    AutomationProperties.HelpText="Press Enter to approve">
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.IsApproving, Mode=OneWay}">
                        <ProgressRing
                            IsActive="True"
                            Width="16"
                            Height="16" />
                        <TextBlock Text="Approving..." />
                    </StackPanel>
                    <Button.Content>
                        <TextBlock
                            Text="Approve"
                            Visibility="{x:Bind ViewModel.IsApproving, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}" />
                    </Button.Content>
                </Button>
            </StackPanel>

            <!-- Status Messages -->
            <InfoBar
                IsOpen="{x:Bind ViewModel.IsExpired, Mode=OneWay}"
                Severity="Error"
                Title="Approval Expired"
                Message="The approval request has expired." />

            <InfoBar
                IsOpen="{x:Bind ViewModel.IsComplete, Mode=OneWay}"
                Severity="Success"
                Title="Approved"
                Message="Challenge approved and signed successfully." />

            <InfoBar
                IsOpen="{x:Bind ViewModel.IsDenied, Mode=OneWay}"
                Severity="Informational"
                Title="Denied"
                Message="Challenge denied." />

            <InfoBar
                IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource StringNotEmptyConverter}}"
                Severity="Error"
                Title="Error"
                Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

        </StackPanel>
    </ScrollViewer>

    <Page.Resources>
        <views:BoolNegationConverter x:Key="BoolNegationConverter"
                                     xmlns:views="using:Sigil.Windows.App.Views" />
        <views:NullToCollapsedConverter x:Key="NullToCollapsedConverter"
                                        xmlns:views="using:Sigil.Windows.App.Views" />
        <views:StringNotEmptyConverter x:Key="StringNotEmptyConverter"
                                       xmlns:views="using:Sigil.Windows.App.Views" />
    </Page.Resources>
</Page>
