  "invalid_cases": [
    {
      "name": "Wrong domain tag (MPA tag used for auth)",
      "challenge_bytes_hex": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
      "action_context_canonical": "{\"description\":\"Sign in to Engine Management\",\"type\":\"engine_login\",\"user_id\":\"alice\"}",
      "domain_tag": "SIGIL-MPA-V1\\x00",
      "expected_result": "reject",
      "reason": "Signature produced with SIGIL-MPA-V1 will not verify against SIGIL-AUTH-V1"
    },
    {
      "name": "Action_context substitution after signing",
      "challenge_bytes_hex": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
      "signed_action": "{\"description\":\"Sign in to Engine Management\",\"type\":\"engine_login\",\"user_id\":\"alice\"}",
      "substituted_action": "{\"type\":\"engine_login\",\"description\":\"Delete all data\",\"user_id\":\"alice\"}",
      "expected_result": "reject",
      "reason": "Different action_context produces different hash, signature fails verification"
    },
    {
      "name": "Non-canonical JSON (whitespace variation)",
      "challenge_bytes_hex": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
      "action_context_non_canonical": "{\"type\": \"engine_login\", \"user_id\": \"alice\", \"description\": \"Sign in to Engine Management\"}",
      "expected_result": "reject",
      "reason": "Different byte representation (whitespace, key order) produces different hash"
    }
