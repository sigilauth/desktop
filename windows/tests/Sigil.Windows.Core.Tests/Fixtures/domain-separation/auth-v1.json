{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Domain Separation Test Vectors - Authentication (V1 with action_context binding)",
  "description": "RFC 6979 deterministic ECDSA signatures with SIGIL-AUTH-V1 domain tag and action_context cryptographic binding",
